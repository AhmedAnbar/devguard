{
    "name": "ahmedanbar/devguard",
    "description": "Developer CLI toolkit for Laravel projects — deploy readiness scoring and architecture enforcement.",
    "type": "library",
    "license": "MIT",
    "keywords": ["cli", "laravel", "devops", "linter", "deployment", "architecture"],
    "require": {
        "php": "^8.2",
        "laravel/prompts": "^0.1 || ^0.2 || ^0.3",
        "nikic/php-parser": "^5.0",
        "symfony/console": "^7.0",
        "symfony/finder": "^7.0",
        "symfony/process": "^7.0",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "pestphp/pest": "^2.0",
        "phpstan/phpstan": "^1.10",
        "laravel/pint": "^1.13"
    },
    "autoload": {
        "psr-4": {
            "DevGuard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "DevGuard\\Tests\\": "tests/"
        }
    },
    "bin": ["bin/devguard"],
    "scripts": {
        "test": "pest",
        "stan": "phpstan analyse",
        "fmt":  "pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
